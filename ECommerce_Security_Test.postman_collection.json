{
	"info": {
		"_postman_id": "8b9e6cde-9a8b-4cde-9f12-c23536de3dfe",
		"name": "ECommerce Security Testing",
		"description": "Collection to test Registration, Login, JWT Access/Refresh tokens, API Protection at Gateway, Data Ownership, and Logout.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register User",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"firstName\": \"Phi Hong\",\n  \"lastName\": \"Nguyen\",\n  \"email\": \"phihong@example.com\",\n  \"phoneNumber\": \"0987654321\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8900/api/auth/register",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"auth",
						"register"
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.accessToken) {",
							"    pm.globals.set(\"accessToken\", jsonData.accessToken);",
							"    pm.globals.set(\"refreshToken\", jsonData.refreshToken);",
							"    pm.globals.set(\"userId\", jsonData.userId);",
							"    pm.globals.set(\"userRole\", jsonData.role);",
							"    console.log(\"Saved tokens and credentials to Globals!\");",
							"}"
						],
						"type": "javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8900/api/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Get Catalog (Public - No Token)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8900/api/catalog",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"catalog"
					]
				}
			},
			"response": []
		},
		{
			"name": "4. Place Order (Protected - No Token - Expect 401)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Cart-Id",
						"value": "cart123",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8900/api/shop/order/{{userId}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"shop",
						"order",
						"{{userId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "5. Place Order (Protected - Wrong User Owner - Expect 403)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Cart-Id",
						"value": "cart123",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8900/api/shop/order/9999",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"shop",
						"order",
						"9999"
					]
				}
			},
			"response": []
		},
		{
			"name": "6. Place Order (Protected - Correct Owner - Expects Authorized)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{accessToken}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Cart-Id",
						"value": "cart123",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8900/api/shop/order/{{userId}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"shop",
						"order",
						"{{userId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "7. Refresh Access Token",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8900/api/auth/refresh?refreshToken={{refreshToken}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"auth",
						"refresh"
					],
					"query": [
						{
							"key": "refreshToken",
							"value": "{{refreshToken}}"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "8. Logout",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8900/api/auth/logout?refreshToken={{refreshToken}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8900",
					"path": [
						"api",
						"auth",
						"logout"
					],
					"query": [
						{
							"key": "refreshToken",
							"value": "{{refreshToken}}"
						}
					]
				}
			},
			"response": []
		}
	]
}
